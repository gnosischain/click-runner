# ClickHouse Configuration
CH_DB_HOST=your-clickhouse-host
CH_NATIVE_PORT=9000
CH_USER=default
CH_PASSWORD=your-password
CH_DB=default
CH_SECURE=False
CH_VERIFY=False

# Dune API Configuration
DUNE_API_KEY=your-dune-api-key

# Dune Query IDs for Labels
DUNE_LABELS_QUERY_ID_DAY=your-labels-daily-query-id
DUNE_LABELS_QUERY_ID_FULL=your-labels-full-query-id
DUNE_LABELS_EXECUTION_ID=your-labels-execution-id

# Dune Query IDs for Prices
DUNE_PRICES_QUERY_ID_DAY=your-prices-daily-query-id
DUNE_PRICES_QUERY_ID_FULL=your-prices-full-query-id
DUNE_PRICES_EXECUTION_ID=your-prices-execution-id

# Dune Query IDs for Bridge Flows
DUNE_BRIDGE_FLOWS_QUERY_ID_DAY=your-bridge-daily-query-id
DUNE_BRIDGE_FLOWS_QUERY_ID_FULL=your-bridge-full-query-id  
DUNE_BRIDGE_FLOWS_EXECUTION_ID=your-bridge-execution-id   

# S3 Configuration (for ProbeLab and other S3-based ingestors)
CH_QUERY_VAR_S3_ACCESS_KEY=your-s3-access-key
CH_QUERY_VAR_S3_SECRET_KEY=your-s3-secret-key
CH_QUERY_VAR_S3_BUCKET=prod-use1-gnosis
CH_QUERY_VAR_S3_REGION=us-east-1

# Ember Data Configuration
EMBER_DATA_URL=https://example.com/path/to/ember/data.csv

# Google Drive Configuration (for gpay-wallets)
GPAY_WALLETS_FILE_ID=your-google-drive-file-id
GOOGLE_APPLICATION_CREDENTIALS=~/.config/gcloud/application_default_credentials.json

# Mixpanel Configuration (sensitive - restricted access)
MIXPANEL_PROJECT_ID=your-mixpanel-project-id
MIXPANEL_SA_USERNAME=your-service-account-username
MIXPANEL_SA_SECRET=your-service-account-secret
MIXPANEL_DATABASE=mixpanel
# Optional: dedicated ClickHouse user for Mixpanel data isolation
MIXPANEL_CH_USER=
MIXPANEL_CH_PASSWORD=
# Backfill date range (only for backfill mode)
MIXPANEL_BACKFILL_FROM=2024-01-01
MIXPANEL_BACKFILL_TO=2025-03-29